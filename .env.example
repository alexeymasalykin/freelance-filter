# Telegram API (https://my.telegram.org)
API_ID=
API_HASH=

# Phone number for Telethon auth
PHONE=+79001234567

# Telegram group ID (negative number)
GROUP_ID=-1001234567890

# LLM evaluation via OpenRouter
LLM_ENABLED=true
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-haiku-4-5

# Response generation (requires BOT_TOKEN)
GENERATE_RESPONSE=true
BOT_TOKEN=
